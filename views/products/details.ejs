<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= product.name %></h1>
  <div>
    <a href="/products/edit/<%= product._id %>" class="btn btn-warning">Modifier</a>
    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">Supprimer</button>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="d-flex justify-content-between">
      ">
        <%= product.inStock ? 'En stock' : 'Rupture de stock' %>
      
      <%= product.category %>
    </div>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-8">
        <h5>Description</h5>
        <p><%= product.description || 'Aucune description' %>

        
        <h5>Détails</h5>
        <ul class="list-group list-group-flush mb-3">
          <li class="list-group-item d-flex justify-content-between">
            Prix:
            <%= product.price.toFixed(2) %> €
          </li>
          <li class="list-group-item d-flex justify-content-between">
            Quantité:
            <%= product.quantity %>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            Créé le:
            <%= new Date(product.createdAt).toLocaleString() %>
          </li>
          <li class="list-group-item d-flex justify-content-between">
            Dernière mise à jour:
            <%= new Date(product.updatedAt).toLocaleString() %>
          </li>
        </ul>
        
        <% if (product.tags && product.tags.length > 0) { %>
          <h5>Tags</h5>
          <div>
            <% product.tags.forEach(tag => { %>
              <%= tag %>
            <% }) %>
          </div>
        <% } %>
      </div>
      <div class="col-md-4">
        <div class="card">
          <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>">
        </div>
      </div>
    </div>
  </div>
  <div class="card-footer">
    <a href="/products" class="btn btn-secondary">Retour à la liste</a>
  </div>
</div>

<!-- Modal de confirmation de suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteModalLabel">Confirmer la suppression</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Êtes-vous sûr de vouloir supprimer le produit "<%= product.name %>" ?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
        <form action="/products/<%= product._id %>/delete" method="POST">
          <button type="submit" class="btn btn-danger">Supprimer</button>
        </form>
      </div>
    </div>
  </div>
</div>